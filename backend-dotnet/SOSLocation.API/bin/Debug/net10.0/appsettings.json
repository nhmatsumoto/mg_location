{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=sos_location;Username=sos_location_user;Password=sos_location_password"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/sos-location",
    "Audience": "sos-location-frontend",
    "RequireHttpsMetadata": false
  }
}
